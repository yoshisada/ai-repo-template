# Local Claude Code hook overrides — users may drop hooks under
# `.claude/hooks/` to wire personal automations. These are personal
# overrides, never plugin-shipped; do not commit.
.claude/hooks/

# Local scheduled-task lock used by /loop / /schedule skills — transient,
# never commit.
.claude/scheduled_tasks.lock

# Transient lockfile used by plugin-shelf/scripts/shelf-counter.sh — never commit
.shelf-config.lock

# Workflow outputs — generated, never commit
reports/
.wheel/outputs/
.wheel/logs/

# Fix records (FR-021) — local fix-recording artifacts; mirrored into Obsidian, not committed
.kiln/fixes/

# Plugin skill test harness — per-run ephemeral artifacts (scratch snapshots,
# NDJSON transcripts, verdict JSON + markdown reports). Never commit.
.kiln/logs/kiln-test-*

# Research-first runner reports (NFR-S-004) — per-run ephemeral comparative
# reports. Maintainers may copy into PR descriptions manually.
.kiln/logs/research-*
