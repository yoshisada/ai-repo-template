{
  "workflow_name": "count-to-100",
  "workflow_file": "workflows/count-to-100.json",
  "workflow": {
    "name": "count-to-100",
    "version": "1.0.0",
    "steps": [
      {
        "id": "init",
        "type": "command",
        "command": "echo '0' > /tmp/wheel-count-100.txt && rm -f /tmp/wheel-count-100-log.txt && echo 'Counter initialized'",
        "output": ".wheel/outputs/count-init.txt"
      },
      {
        "id": "count-loop",
        "type": "loop",
        "condition": "test $(cat /tmp/wheel-count-100.txt) -ge 100",
        "max_iterations": 101,
        "on_exhaustion": "fail",
        "substep": {
          "type": "command",
          "command": "COUNT=$(cat /tmp/wheel-count-100.txt) && COUNT=$((COUNT + 1)) && echo $COUNT > /tmp/wheel-count-100.txt && echo $COUNT >> /tmp/wheel-count-100-log.txt && echo $COUNT"
        }
      },
      {
        "id": "report",
        "type": "command",
        "command": "FINAL=$(cat /tmp/wheel-count-100.txt) && echo \"Counted to $FINAL\" && echo '---' && cat /tmp/wheel-count-100-log.txt",
        "output": ".wheel/outputs/count-100-result.txt",
        "terminal": true
      }
    ]
  },
  "cursor": 3,
  "status": "complete",
  "owner_session_id": "test-session-2085",
  "owner_agent_id": "test-agent-2085",
  "started_at": "2026-04-07T01:26:37Z",
  "completed_at": "2026-04-07T01:26:37Z",
  "step_results": {
    "init": {
      "status": "success",
      "output_file": ".wheel/outputs/count-init.txt"
    },
    "count-loop": {
      "status": "success",
      "iterations": 100
    },
    "report": {
      "status": "success",
      "output_file": ".wheel/outputs/count-100-result.txt"
    }
  }
}
