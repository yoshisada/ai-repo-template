{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/node_modules/@yoshisada/kiln/hooks/require-spec.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/node_modules/@yoshisada/kiln/hooks/require-feature-branch.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/node_modules/@yoshisada/kiln/hooks/version-increment.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/node_modules/@yoshisada/kiln/hooks/block-env-commit.sh\""
          }
        ]
      }
    ]
  }
}
