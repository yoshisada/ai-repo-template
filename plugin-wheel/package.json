{
  "name": "@yoshisada/wheel",
  "version": "000.001.009.1670",
  "description": "Hook-based workflow engine for Claude Code agent pipelines",
  "author": "yoshisada",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./shared": {
      "import": "./dist/shared/index.js",
      "types": "./dist/shared/index.d.ts"
    }
  },
  "bin": {
    "wheel": "./bin/init.mjs"
  },
  "files": [
    ".claude-plugin/",
    "hooks/",
    "lib/",
    "bin/",
    "scaffold/",
    "skills/",
    "workflows/",
    "README.md"
  ],
  "keywords": [
    "claude-code",
    "plugin",
    "workflow-engine",
    "hooks",
    "agent-orchestration",
    "deterministic-pipeline"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yoshisada/ai-repo-template.git",
    "directory": "plugin-wheel"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:unit": "vitest run src/shared/ src/lib/",
    "test:harness": "bash tests/harness/run.sh",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
