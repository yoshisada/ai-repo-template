# Wheel test-harness credentials template.
#
# Copy this file to `plugin-wheel/.env.test` and fill in real values.
# That path is gitignored (via the repo-root `.env.*` rule) and is
# auto-loaded by `plugin-wheel/scripts/harness/wheel-test-runner.sh` at
# startup, so any fixture's `require-env:` declarations resolve against
# these values without you having to `source` anything manually.
#
# Each block below corresponds to one provider / fixture family. Only
# fill in the blocks for fixtures you actually want to run; missing
# require-env vars cause the matching fixture to TAP-SKIP cleanly.

# -----------------------------------------------------------------------------
# Bifrost-hosted MiniMax (or other Bifrost-routed providers)
# Used by: plugin-wheel/tests/bifrost-minimax-smoke/
# -----------------------------------------------------------------------------
# Anthropic-compatible endpoint exposed by your Bifrost deployment
BIFROST_ENDPOINT=
# Bifrost gateway API key
BIFROST_API_KEY=
# Provider/model id Bifrost routes to MiniMax (e.g. minimax/MiniMax-M2)
BIFROST_MODEL_ID=

# -----------------------------------------------------------------------------
# Bedrock-hosted Anthropic models
# Used by: plugin-wheel/tests/third-party-bedrock-smoke/  (if present)
# -----------------------------------------------------------------------------
# WHEEL_TEST_BEDROCK_URL=
# WHEEL_TEST_BEDROCK_TOKEN=

# -----------------------------------------------------------------------------
# Vertex AI-hosted Anthropic models
# Used by: plugin-wheel/tests/third-party-vertex-smoke/  (if present)
# -----------------------------------------------------------------------------
# WHEEL_TEST_VERTEX_URL=
# WHEEL_TEST_VERTEX_TOKEN=

# -----------------------------------------------------------------------------
# Demo skip fixture — these are deliberately pathological so the
# `third-party-model-skip-demo` fixture always SKIPS in CI. Only set
# them locally to convert that fixture into a live probe.
# -----------------------------------------------------------------------------
# WHEEL_TEST_THIRD_PARTY_DEMO_BASE_URL=
# WHEEL_TEST_THIRD_PARTY_DEMO_TOKEN=
